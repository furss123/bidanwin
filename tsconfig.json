{
  // Root TypeScript config shared across main, preload, and renderer
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "electron.vite.config.ts"
  ]
}
